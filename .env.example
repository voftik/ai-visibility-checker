OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-opus-4.7
HOST=0.0.0.0
PORT=8000
DEFAULT_CONCURRENCY=8
DEFAULT_TIMEOUT_SECONDS=15

# Webshare.io proxy pool (optional).
# Leave WEBSHARE_API_KEY empty to disable proxying — crawler will talk directly.
WEBSHARE_API_KEY=
PROXY_ENABLED=true
PROXY_REFRESH_INTERVAL_SECONDS=3600
PROXY_FALLBACK_DIRECT=true
PROXY_COOLDOWN_SECONDS=300
